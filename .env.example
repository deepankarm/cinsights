# Required: LLM API key (also reads ANTHROPIC_API_KEY as fallback)
ANTHROPIC_API_KEY=sk-ant-...
# CINSIGHTS_LLM_API_KEY=sk-ant-...   # alternative, provider-agnostic key

# Provider/model configuration is best set via ~/.cinsights/config.json
# (run `cinsights setup` to configure interactively), but can also be
# overridden via env vars:
# CINSIGHTS_LLM_PROVIDER=anthropic           # anthropic / openai / etc.
# CINSIGHTS_LLM_MODEL=claude-sonnet-4-20250514
# CINSIGHTS_LLM_BASE_URL=                    # custom gateway / proxy URL
# CINSIGHTS_LLM_EXTRA_HEADERS='{}'           # JSON string of extra HTTP headers

# Optional: Override defaults
# CINSIGHTS_PHOENIX_ENDPOINT=http://localhost:6006
# CINSIGHTS_DATABASE_URL=sqlite:///cinsights.db
# CINSIGHTS_HOST=127.0.0.1
# CINSIGHTS_PORT=8100
